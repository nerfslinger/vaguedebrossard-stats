*.bak
*.bak2
*.orig
*.tmp

# ── OS / editor noise ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Node (only relevant if a build step is ever added) ─────────────
node_modules/

